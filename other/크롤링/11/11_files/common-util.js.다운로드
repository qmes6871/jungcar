/*
 - 팝업 등 특정 영역을 PDF 파일로 다운로드 하는 함수
 - 다운로드 할 영역 id="prf_print_wrap" 로 지정
*/
function htmlToPdf(fileName, contentMap) {
    // 출력 영역 clone -> 가상 DOM 생성
    const orgWrap = document.getElementById('pdf_print_wrap');
    const clonedWrap = orgWrap.cloneNode(true);

    // 가상 DOM에서 내용 변경
    for (const id in contentMap) {
        const cell = clonedWrap.querySelector('#' + id);
        if (cell) {
            cell.textContent = contentMap[id];
        }
    }

    // 가상 DOM 에서 인쇄하기 버튼 삭제
    const btn_print = clonedWrap.querySelector('#btn_print');
    btn_print.remove();

    // 가상 DOM을 화면에 보이지 않게 추가
    const hiddenContainer = document.createElement('div');
    hiddenContainer.style.position = 'fixed';
    hiddenContainer.style.top = '-10000px';
    
    hiddenContainer.appendChild(clonedWrap);
    document.body.appendChild(hiddenContainer);

    // 가상 DOM을 캡처하여 PDF로 변환
    html2canvas(clonedWrap).then(canvas => {
        const imgData = canvas.toDataURL('image/png');
        const pdf = new jsPDF();

        // PDF 페이지 크기와 이미지 크기
        const pdfWidth = pdf.internal.pageSize.getWidth();
        const pdfHeight = pdf.internal.pageSize.getHeight();
        const imgWidth = canvas.width;
        const imgHeight = canvas.height;

        // 여백 설정 (단위: mm)
        const margin = 10;
        const contentWidth = pdfWidth - 2 * 30;
        const contentHeight = pdfHeight - 2 * margin;

        // 이미지 크기 조정 비율 계산
        const scaleFactor = Math.min(contentWidth / imgWidth, contentHeight / imgHeight);

        // 이미지의 새로운 크기
        const newWidth = imgWidth * scaleFactor;
        const newHeight = imgHeight * scaleFactor;

        // 이미지를 중앙에 배치하기 위한 좌표 계산
        const x = (pdfWidth - newWidth) / 2;
        const y = (pdfHeight - newHeight) / 2;

        // 이미지 추가
        pdf.addImage(imgData, 'PNG', x, y, newWidth, newHeight);
        pdf.save(fileName+".pdf");

        // 가상 DOM 제거
        document.body.removeChild(hiddenContainer);
    });
}

