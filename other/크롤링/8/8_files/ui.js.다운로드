function popOpen(obj){
    var main = $(".wrapcontent");
    var body = $("body");
    var html = $("html");
    main.css({"width": main.width() + "px"});
    body.css("overflow", "hidden");
    var bst = body.scrollTop(),
        hst = html.scrollTop();
    var comName = $.trim($(obj).attr("class").replace("btn_", ""));
    if(comName.indexOf("_pop") != -1){
        comName = $.trim(comName.replace("modalpop", ""));
    }else{
        comName = comName+"_pop";
    }
    $("."+comName).css("top", bst !== 0 ? bst + "px" : (hst !== 0 ? hst + "px" : ""));
    $("."+comName).show();
}

