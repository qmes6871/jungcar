generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Car {
  id           Int       @id @default(autoincrement())
  brand        String    // Hyundai, Kia, Genesis, etc.
  model        String    // Model name
  year         Int       // Year
  mileage      Int       // Mileage in km
  price        Int       // Price in USD
  fuel         String    // Gasoline, Diesel, Electric, Hybrid
  transmission String    // Automatic, Manual
  bodyType     String    // Sedan, SUV, Truck, Van, etc.
  color        String    // Color
  images       String    @db.Text // JSON array of image URLs
  description  String?   @db.Text
  status       String    @default("available") // available, sold, reserved
  featured     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  inquiries    Inquiry[]

  @@index([brand])
  @@index([status])
  @@index([featured])
}

model Inquiry {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  message   String   @db.Text
  carId     Int?
  car       Car?     @relation(fields: [carId], references: [id])
  createdAt DateTime @default(now())

  @@index([carId])
}
