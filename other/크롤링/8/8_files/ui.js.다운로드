function popClose(obj){
   var main = $(".wrapcontent");
    var body = $("body");
    var html = $("html");
    $("."+obj).fadeOut("fast", function () {
        body.css("overflow", "");
        main.css("width", "");
        $(this).css("top", "");
        $(this).hide();
    });
}


$(document).ready(function() {  
    $(".close").click(function(){
        var popClsNm = $.trim($(this).parent().parent().parent().attr("class").replace("modalpop", ""));
        popClose(popClsNm);
    });
    $(".btn_cancel").click(function(){
        $(".close").each(function(){
          $(this).click();  
        })
    });

    $(".layclk").click(function(e){ 
        $(".slayer").show();
        $(".slayer").offset({
            left:e.pageX + "- 100",
            top:e.pageY
        });
    });
});


